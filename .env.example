# ============================================
# LLM Provider Configuration (example)
# Copy to .env and fill in your keys.
# ============================================

# Select provider: "deepseek" | "openai" | "anthropic" | "mock"
LLM_PROVIDER=deepseek

# Production B memory storage. The local acceptance helper uses these defaults.
NEWIDE_B_DATABASE_URL=postgresql://newide:newide_local@127.0.0.1:55432/newide_b

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (future)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (future)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
